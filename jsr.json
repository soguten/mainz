{
  "$schema": "https://jsr.io/schema/config-file.v1.json",
  "name": "@mainz/mainz",
  "version": "0.1.0-alpha.82",
  "license": "MIT",
  "compilerOptions": {
    "lib": [
      "dom",
      "deno.ns",
      "es2022"
    ],
    "strict": true
  },
  "imports": {
    "@std/jsonc": "npm:@jsr/std__jsonc@^1",
    "happy-dom": "npm:happy-dom@20.9.0",
    "typescript": "npm:typescript@5.9.3",
    "tsx": "npm:tsx@4.22.4",
    "vite": "npm:vite@8.0.16"
  },
  "exports": {
    ".": "./mod.js",
    "./config": "./src/public/config.js",
    "./di": "./src/public/di.ts",
    "./http": "./src/public/http.ts",
    "./http/testing": "./src/public/http-testing.ts",
    "./i18n": "./src/public/i18n.ts",
    "./testing": "./src/public/testing.ts",
    "./tooling/bootstrap-cli": "./src/public/tooling-bootstrap-cli.ts",
    "./tooling/cli": "./src/public/tooling-cli.js",
    "./tooling/build": "./src/public/tooling-build.ts",
    "./tooling/vite-build": "./src/public/tooling-vite-build.ts",
    "./tooling/vite-build-node": "./src/public/tooling-vite-build-node.ts",
    "./tooling/config": "./src/public/tooling-config.ts",
    "./tooling/diagnostics": "./src/diagnostics/index.ts",
    "./tooling/runtime": "./src/public/tooling-runtime.ts",
    "./tooling/server": "./src/public/tooling-server.ts",
    "./tooling/vite": "./src/public/tooling-vite.js",
    "./jsx-runtime": "./src/jsx-runtime.js",
    "./jsx-dev-runtime": "./src/jsx-dev-runtime.js"
  },
  "publish": {
    "include": [
      "LICENSE",
      "README.md",
      "mod.js",
      "mod.ts",
      "src/**",
      "templates/**",
      "templates/container/dockerignore/files/.dockerignore.tpl",
      "templates/project/deno/empty/files/.gitignore.tpl",
      "templates/project/deno/starter/files/.gitignore.tpl",
      "templates/project/node/empty/files/.npmrc.tpl",
      "templates/project/node/empty/files/.gitignore.tpl",
      "templates/project/node/starter/files/.gitignore.tpl",
      "templates/project/node/starter/files/.npmrc.tpl"
    ],
    "exclude": [
      "**/tests/**",
      "src/tests/**",
      "**/*.fixture.ts",
      "**/*.fixture.tsx",
      "**/_template.*"
    ]
  }
}
