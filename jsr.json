{
    "$schema": "https://jsr.io/schema/config-file.v1.json",
    "name": "@mainz/mainz",
    "version": "0.1.0-alpha.25",
    "license": "MIT",
    "compilerOptions": {
        "lib": [
            "dom",
            "deno.ns",
            "es2022"
        ],
        "strict": true
    },
    "imports": {
        "@deno/vite-plugin": "npm:@deno/vite-plugin@2.0.2",
        "happy-dom": "npm:happy-dom@20.1.0",
        "vite": "npm:vite@7.3.1"
    },
    "exports": {
        ".": "./mod.ts",
        "./cli": "./src/cli/mainz.ts",
        "./config": "./src/public/config.ts",
        "./di": "./src/public/di.ts",
        "./http": "./src/public/http.ts",
        "./http/testing": "./src/public/http-testing.ts",
        "./i18n": "./src/public/i18n.ts",
        "./testing": "./src/public/testing.ts",
        "./jsx-runtime": "./src/jsx-runtime.ts",
        "./jsx-dev-runtime": "./src/jsx-dev-runtime.ts"
    },
    "publish": {
        "include": [
            "LICENSE",
            "README.md",
            "mod.ts",
            "src/public/**",
            "src/authorization/**",
            "src/commands/index.ts",
            "src/components/component-dom.ts",
            "src/components/component-events.ts",
            "src/components/component-load.ts",
            "src/components/component-metadata.ts",
            "src/components/component-patching.ts",
            "src/components/component-render-strategy-guardrails.ts",
            "src/components/component.ts",
            "src/components/page-contract.ts",
            "src/components/page-metadata.ts",
            "src/components/page.ts",
            "src/components/registry.ts",
            "src/components/route-context.ts",
            "src/components/types.ts",
            "src/commands/command.ts",
            "src/commands/runtime.ts",
            "src/commands/shortcut.ts",
            "src/build/**",
            "src/cli/app-scaffold.ts",
            "src/cli/mainz.ts",
            "src/compiler/typescript.ts",
            "src/config/definition.ts",
            "src/config/index.ts",
            "src/config/public-entrypoints.ts",
            "src/config/types.ts",
            "src/diagnostics/**",
            "src/di/**",
            "src/http/index.ts",
            "src/http/testing.ts",
            "src/i18n/**",
            "src/jsx-runtime.ts",
            "src/jsx-dev-runtime.ts",
            "src/jsx/**",
            "src/navigation/index.ts",
            "src/navigation/internal.ts",
            "src/portal/**",
            "src/resources/**",
            "src/routing/filesystem.ts",
            "src/routing/index.ts",
            "src/routing/manifest.ts",
            "src/routing/page-discovery-errors.ts",
            "src/routing/page-discovery.ts",
            "src/routing/server.ts",
            "src/routing/target-page-discovery.ts",
            "src/routing/types.ts",
            "src/runtime-events.ts",
            "src/preview/**",
            "src/ssg/happy-dom.ts",
            "src/testing/async-testing.ts",
            "src/testing/mainz-testing.ts",
            "src/testing/navigation-testing.ts",
            "src/testing/test-screen.ts"
        ],
        "exclude": [
            "**/tests/**",
            "src/tests/**",
            "**/*.fixture.ts",
            "**/*.fixture.tsx",
            "**/_template.*"
        ]
    }
}
