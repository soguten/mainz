{
    "$schema": "https://jsr.io/schema/config-file.v1.json",
    "name": "@mainz/runtime-deno",
    "version": "0.1.0-alpha.32",
    "license": "MIT",
    "compilerOptions": {
        "lib": [
            "dom",
            "deno.ns",
            "es2022"
        ],
        "strict": true
    },
    "imports": {
        "@deno/vite-plugin": "npm:@deno/vite-plugin@2.0.2",
        "happy-dom": "npm:happy-dom@20.1.0",
        "vite": "npm:vite@7.3.1"
    },
    "exports": {
        ".": "./mod.runtime-deno.ts"
    },
    "publish": {
        "include": [
            "LICENSE",
            "README.runtime-deno.md",
            "mod.runtime-deno.ts",
            "src/**"
        ],
        "exclude": [
            "**/tests/**",
            "src/tests/**",
            "**/*.fixture.ts",
            "**/*.fixture.tsx",
            "**/_template.*"
        ]
    }
}
