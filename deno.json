{
    "nodeModulesDir": "auto",
    "unstable": [
        "sloppy-imports"
    ],
    "compilerOptions": {
        "lib": [
            "dom",
            "esnext"
        ],
        "jsx": "react-jsx",
        "jsxImportSource": "mainz",
        "strict": true,
        "types": [
            "npm:vite@7.3.1/client",
            "./src/types/jsx.d.ts",
            "./src/types/mainz-env.d.ts"
        ]
    },
    "imports": {
        "mainz": "./src/index.ts",
        "mainz/di": "./src/di/index.ts",
        "mainz/http": "./src/http/index.ts",
        "mainz/http/testing": "./src/http/testing.ts",
        "mainz/i18n": "./src/i18n/index.ts",
        "mainz/testing": "./src/testing/index.ts",
        "mainz/diagnostics": "./src/diagnostics.ts",
        "mainz/config": "./src/config/index.ts",
        "mainz/typecase": "../typecase/src/index.ts",
        "mainz/jsx-runtime": "./src/jsx-runtime.ts",
        "mainz/jsx-dev-runtime": "./src/jsx-dev-runtime.ts",
        "@/": "./src/",
        "@components/": "./src/components/",
        "@std/assert": "jsr:@std/assert",
        "vite": "npm:vite@7.3.1",
        "@deno/vite-plugin": "npm:@deno/vite-plugin@2.0.2",
        "happy-dom": "npm:happy-dom@20.1.1"
    },
    "fmt": {
        "indentWidth": 4,
        "useTabs": false,
        "lineWidth": 100
    },
    "lint": {
        "rules": {
            "exclude": [
                "no-sloppy-imports"
            ]
        }
    },
    "tasks": {
        "mainz": "deno run -A ./src/cli/mainz.ts",
        "dev": "deno run -A ./src/cli/mainz.ts dev",
        "build": "deno run -A ./src/cli/mainz.ts build",
        "preview": "deno run -A ./src/cli/mainz.ts preview",
        "publish-info": "deno run -A ./src/cli/mainz.ts publish-info",
        "diagnose": "deno run -A ./src/cli/mainz.ts diagnose",
        "sync:templates": "deno run -A ./scripts/sync-templates.ts",
        "test": "deno test -A",
        "test:fast": "deno test -A src/components/tests src/config/tests src/i18n/tests src/jsx/tests src/navigation/tests src/routing/tests src/testing/tests src/cli/tests",
        "test:e2e": "deno test -A --filter \"^e2e/\" tests/e2e",
        "test:e2e:core": "deno test -A tests/matrix/suite.test.ts tests/matrix/single-locale-suite.test.ts tests/matrix/base-path-suite.test.ts tests/matrix/head-seo-suite.test.ts tests/matrix/generated-tag-stability-suite.test.ts tests/matrix/routed-di-entries-suite.test.ts tests/matrix/routed-di-client-suite.test.ts tests/matrix/routed-authorization-suite.test.ts",
        "test:e2e:special": "deno test -A tests/matrix/harness.test.ts",
        "test:smoke": "deno test -A tests/e2e/smoke/build.csr-routing.e2e.test.ts tests/e2e/smoke/build.csr-spa.e2e.test.ts tests/e2e/smoke/build.single-locale-routing.smoke.e2e.test.ts"
    },
    "workspace": []
}
