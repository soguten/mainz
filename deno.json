{
    "nodeModulesDir": "auto",
    "unstable": [
        "sloppy-imports"
    ],
    "compilerOptions": {
        "lib": [
            "dom",
            "esnext"
        ],
        "jsx": "react-jsx",
        "jsxImportSource": "mainz",
        "strict": true,
        "types": [
            "npm:vite/client",
            "./src/types/jsx.d.ts"
        ]
    },
    "imports": {
        "mainz": "./src/index.ts",
        "mainz/jsx-runtime": "./src/jsx-runtime.ts",
        "mainz/jsx-dev-runtime": "./src/jsx-dev-runtime.ts",
        "@/": "./src/",
        "@components/": "./src/components/",
        "@jsx/": "./src/jsx/",
        "@std/assert": "jsr:@std/assert",
        "vite": "npm:vite",
        "happy-dom": "npm:happy-dom"
    },
    "lint": {
        "rules": {
            "exclude": [
                "no-sloppy-imports"
            ]
        }
    },
    "tasks": {
        "dev": "deno run -A npm:vite --config vite.config.playground.ts",
        "build:site": "deno run -A npm:vite build --config vite.config.site.ts",
        "preview:site": "deno run -A npm:vite preview --config vite.config.site.ts",
        "test": "deno test -A"
    }
}