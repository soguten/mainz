{
    "$schema": "https://jsr.io/schema/config-file.v1.json",
    "name": "@mainz/runtime-node",
    "version": "0.1.0-alpha.31",
    "license": "MIT",
    "compilerOptions": {
        "lib": [
            "dom",
            "deno.ns",
            "es2022"
        ],
        "strict": true
    },
    "exports": {
        ".": "./mod.runtime-node.ts"
    },
    "publish": {
        "include": [
            "LICENSE",
            "README.runtime-node.md",
            "mod.runtime-node.ts",
            "src/**"
        ],
        "exclude": [
            "**/tests/**",
            "src/tests/**",
            "**/*.fixture.ts",
            "**/*.fixture.tsx",
            "**/_template.*"
        ]
    }
}
